{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile metadata",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The firebase auth UID of the user" },
        "email": { "type": "string", "description": "The email address of the user" },
        "displayName": { "type": "string", "description": "The readable display name of the user" },
        "role": { "type": "string", "enum": ["user", "admin"], "description": "The access level of the user" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["uid", "email", "role"]
    },
    "Room": {
      "title": "Room",
      "description": "Information about bookable rooms",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier for the room" },
        "name": { "type": "string", "description": "Display name of the room" },
        "capacity": { "type": "integer", "description": "Capacity of the room" },
        "layoutType": { "type": "string", "enum": ["Boardroom", "Conference", "U-Shape", "Lecture", "Project Room"], "description": "Seating layout orientation" },
        "amenities": { "type": "array", "description": "List of available room technologies" },
        "description": { "type": "string", "description": "Short textual description of the room" },
        "imageUrl": { "type": "string", "description": "URL of the room representative image" }
      },
      "required": ["id", "name", "capacity", "layoutType", "description"]
    },
    "Booking": {
      "title": "Booking",
      "description": "A single room reservation record",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique reservation identifier" },
        "roomId": { "type": "string", "description": "Id of the room being reserved" },
        "roomName": { "type": "string", "description": "Cached name of the room at reservation time" },
        "userId": { "type": "string", "description": "UID of the reserving user" },
        "userEmail": { "type": "string", "description": "Email of the reserving user" },
        "userName": { "type": "string", "description": "Display name of the reserving user" },
        "date": { "type": "string", "description": "Format YYYY-MM-DD" },
        "startTime": { "type": "string", "description": "Format HH:MM" },
        "endTime": { "type": "string", "description": "Format HH:MM" },
        "purpose": { "type": "string", "description": "The specified objective for the room usage" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"], "description": "Approval workflow state" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Server-generated timestamp" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Server-generated modification timestamp" }
      },
      "required": ["id", "roomId", "roomName", "userId", "userEmail", "date", "startTime", "endTime", "purpose", "status", "createdAt", "updatedAt"]
    },
    "Admin": {
      "title": "Admin",
      "description": "Explicit pointer document to signify a user is a hard admin",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" }
      },
      "required": ["uid", "email"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles and settings"
    },
    "rooms/{roomId}": {
      "schema": "Room",
      "description": "Catalog of available corporate or community spaces"
    },
    "bookings/{bookingId}": {
      "schema": "Booking",
      "description": "Central ledger of room booking activities"
    },
    "admins/{adminId}": {
      "schema": "Admin",
      "description": "Exclusively structured database table for authorized admin roles"
    }
  }
}
